# ProcurBosse — EL5 MediProcure Environment Configuration
# Embu Level 5 Hospital, Embu County Government
# DO NOT COMMIT this file with real secrets to public repos

# ── Supabase Configuration (REQUIRED) ────────────────────────────
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key_here
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_SERVICE_ROLE_KEY=""

# ── Hospital Configuration (overrides DB system_settings) ────────
VITE_HOSPITAL_NAME="Embu Level 5 Hospital"
VITE_COUNTY_NAME="Embu County Government"
VITE_SYSTEM_NAME="EL5 MediProcure"
VITE_APP_VERSION="2.0.0"

# ── Electron Configuration ────────────────────────────────────────
# Set to '1' during development to load from localhost:8080
ELECTRON_DEV=""

# ── Email/SMTP (configured via Settings page in-app) ─────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── SMS/Twilio (configured via Settings page in-app) ─────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
