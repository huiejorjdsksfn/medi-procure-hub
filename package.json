{
  "name": "procurbosse",
  "private": true,
  "version": "12.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:8080 && cross-env ELECTRON_DEV=1 electron electron/main.js\"",
    "electron:build": "npm run build && electron-builder --config electron-builder.yml",
    "electron:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "electron:win:x64": "npm run build && electron-builder --win --x64 --config electron-builder.yml",
    "electron:win:ia32": "npm run build && electron-builder --win --ia32 --config electron-builder.yml",
    "release:v1": "cross-env APP_VERSION=1.0.0 npm run electron:win",
    "release:v2": "cross-env APP_VERSION=2.0.0 npm run electron:win",
    "build:prod": "vite build --mode production",
    "electron:build:x64": "npm run build && electron-builder --win --x64 --config electron-builder.yml",
    "electron:build:ia32": "npm run build && electron-builder --win --ia32 --config electron-builder.yml",
    "electron:build:both": "npm run build && electron-builder --win --x64 --ia32 --config electron-builder.yml",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "typecheck": "tsc --noEmit"
  },
