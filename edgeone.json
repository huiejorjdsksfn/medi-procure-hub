{
  "build": {
    "command": "echo 'Using pre-built web directory'",
    "directory": "web",
    "environment": {
      "NODE_VERSION": "20",
      "CI": "false"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "headers": { "cache-control": "public, max-age=86400" } },
    { "src": "/icons/(.*)",  "headers": { "cache-control": "public, max-age=86400" } },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
