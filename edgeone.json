{
  "build": {
    "command": "echo 'Serving pre-built web directory'",
    "directory": "web",
    "environment": {
      "NODE_VERSION": "20",
      "CI": "false"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "headers": { "cache-control": "public, max-age=86400, immutable" } },
    { "src": "/icons/(.*)",  "headers": { "cache-control": "public, max-age=86400" } },
    { "src": "/favicon.ico", "headers": { "cache-control": "public, max-age=86400" } },
    { "src": "/favicon.png", "headers": { "cache-control": "public, max-age=86400" } },
    { "src": "/manifest.json", "headers": { "cache-control": "no-cache" } },
    { "src": "/sw.js", "headers": { "cache-control": "no-cache, no-store, must-revalidate" } },
    { "src": "/(.*)", "dest": "/index.html", "status": 200 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
