{
  "build": {
    "command": "echo 'pre-built'",
    "directory": "web",
    "environment": {
      "NODE_VERSION": "20",
      "CI": "false"
    }
  },
  "rewrites": [
    { "source": "/((?!assets/|icons/|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/index.html", "status": 200 }
  ],
  "errorPage": {
    "404": "/index.html"
  }
}
