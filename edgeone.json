{
  "build": {
    "command": "ELECTRON_SKIP_BINARY_DOWNLOAD=1 npm install --legacy-peer-deps --no-audit && npm run build",
    "directory": "dist",
    "environment": {
      "NODE_VERSION": "20",
      "ELECTRON_SKIP_BINARY_DOWNLOAD": "1",
      "NODE_OPTIONS": "--max-old-space-size=4096"
    }
  },
  "routes": [
    {"src": "/assets/(.*)", "headers": {"cache-control": "public, max-age=31536000, immutable"}},
    {"src": "/icons/(.*)",  "headers": {"cache-control": "public, max-age=86400"}},
    {"src": "/(.*)",        "dest": "/index.html"}
  ]
}
