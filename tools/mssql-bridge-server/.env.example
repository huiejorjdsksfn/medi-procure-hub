# Shared secret — must match what's saved in the app's SQL Server Bridge
# settings (Admin → Database → SQL Server Bridge). Generate a real random
# value, e.g.: openssl rand -hex 32
SQLSERVER_BRIDGE_SECRET=change-me-to-a-real-random-secret

PORT=4390

MSSQL_SERVER=PROD-SQL01\INSTANCE
MSSQL_DATABASE=EL5_MediProcure_Migrated
MSSQL_TRUSTED_CONNECTION=no
MSSQL_USER=sa
MSSQL_PASSWORD=your-sql-server-password
MSSQL_ENCRYPT=yes
MSSQL_TRUST_SERVER_CERT=yes
